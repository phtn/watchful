{
  "manifest_version": 3,
  "name": "Watchful Wind",
  "version": "1.0",
  "description": "Watch game results and calculate averages",

  "permissions": ["storage", "activeTab", "sidePanel", "tabs"],

  "content_scripts": [
    {
      "matches": [
        "*://bet88.ph/*",
        "*://*.bet88.ph/*",
        "*://*.ap.blink.run/*",
        "*://stake.com/*",
        "*://*.stake.com/*",
        "*://*.evo-games.com/*",
        "*://*.evolution.com/*",
        "*://*.evolutiongaming.com/*",
        "*://*.ezugi.com/*"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],

  "background": {
    "service_worker": "dist/background.js"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "action": {
    "default_title": "Watchful Wind",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["dist/injected.js"],
      "matches": ["*://*/*"]
    }
  ]
}
